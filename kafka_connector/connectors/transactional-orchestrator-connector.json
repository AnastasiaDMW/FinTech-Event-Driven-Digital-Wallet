{
  "name": "${TRANSACTIONAL_ORCHESTRATOR_NAME}",
  "config": {
    "connector.class": "io.debezium.connector.postgresql.PostgresConnector",
    "database.hostname": "${TRANSACTIONAL_ORCHESTRATOR_HOSTNAME}",
    "database.port": "5432",
    "database.user": "${DEBEZIUM_USER}",
    "database.password": "${DEBEZIUM_PASSWORD}",
    "database.dbname": "${TRANSACTIONAL_ORCHESTRATOR_DBNAME}",
    "database.server.name": "${TRANSACTIONAL_ORCHESTRATOR_SERVER_NAME}",
    "publication.name": "outbox_pub",
    "publication.autocreate.mode": "disabled",
    "slot.name": "debezium_kafka_outbox_slot",
    "table.include.list": "public.tbl_outbox",
    "plugin.name": "pgoutput",
    "topic.prefix": "topic",
    "transforms": "outbox",
    "key.converter": "org.apache.kafka.connect.storage.StringConverter",
    "value.converter": "org.apache.kafka.connect.json.JsonConverter",
    "value.converter.schemas.enable": "false",
    "transforms.outbox.type": "io.debezium.transforms.outbox.EventRouter",

    "transforms.outbox.table.field.event.id": "id",
    "transforms.outbox.table.field.event.key": "event_key",
    "transforms.outbox.table.field.event.type": "event_type",
    "transforms.outbox.table.field.event.payload": "payload",

    "transforms.outbox.route.by.field": "category",
    "transforms.outbox.route.topic.replacement": "${routedByValue}",

    "transforms.outbox.table.expand.json.payload": "true",
    "transforms.outbox.value.field": "payload",

    "transforms.outbox.remove.table.fields": "true"
  }
}